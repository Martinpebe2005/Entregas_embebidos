void uart_init(void) {
    uart_config_t uart_config = {
        .baud_rate  = 115200,              // Velocidad: 115200 símbolos/segundo
        .data_bits  = UART_DATA_8_BITS,    // 8 bits de datos por trama
        .parity     = UART_PARITY_DISABLE, // Sin bit de paridad (N)
        .stop_bits  = UART_STOP_BITS_1,    // 1 stop bit (1)
        .flow_ctrl  = UART_HW_FLOWCTRL_DISABLE, // Sin control de flujo por hardware
        .source_clk = UART_SCLK_DEFAULT,   // Reloj interno por defecto
    };

    // Aplica la configuración al periférico UART0
    uart_param_config(UART_NUM_0, &uart_config);

    // Usa los pines por defecto del UART0 (los del USB-Serial integrado)
    uart_set_pin(UART_NUM_0, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE);

    // Instala el driver: reserva BUF_SIZE bytes para RX y TX en memoria
    // Los últimos 3 parámetros (0, NULL, 0) indican que no usamos interrupciones por cola
    uart_driver_install(UART_NUM_0, BUF_SIZE, BUF_SIZE, 0, NULL, 0);
}

// Empaqueta los datos en un string legible y los transmite por TX
void uart_send(float temp_control, float temp_sensor, int led_pct) {
    char buf[64];
    // Formatea el mensaje: ej. "Tc:22.0 T:25.3 LED:80%\n"
    sprintf(buf, "Tc:%.1f T:%.1f LED:%d%%\n", temp_control, temp_sensor, led_pct);
    // Envía los bytes por la línea TX del UART0
    uart_write_bytes(UART_NUM_0, buf, strlen(buf));
}

// Escucha el puerto RX buscando el comando "SET_TEMP:XX"
// Retorna la nueva temperatura si llegó el comando, o -1 si no hay nada
float uart_receive_set_temp(void) {
    uint8_t rx_buf[BUF_SIZE];

    // Lee bytes disponibles en el buffer RX
    // Espera máximo 10ms antes de continuar (no bloquea el programa)
    int len = uart_read_bytes(UART_NUM_0, rx_buf, BUF_SIZE - 1, 10 / portTICK_PERIOD_MS);

    if (len > 0) {
        rx_buf[len] = '\0'; // Termina el string para poder procesarlo con sscanf

        float val;
        // Intenta extraer el número XX del comando "SET_TEMP:XX"
        // sscanf retorna 1 si encontró exactamente un valor flotante
        if (sscanf((char*)rx_buf, "SET_TEMP:%f", &val) == 1) {
            return val; // Comando válido: retorna la nueva Tc
        }
    }
    return -1; // No llegó ningún comando válido
}
