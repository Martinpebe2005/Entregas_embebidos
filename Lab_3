#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/uart.h"
#include "driver/gpio.h"
#include "driver/ledc.h"
#include "driver/timer.h"
#include "esp_adc/adc_oneshot.h"
#include "esp_adc/adc_cali.h"
#include "esp_adc/adc_cali_scheme.h"
#include <string.h>
#include <stdio.h>

// ─── DEFINES ───────────────────────────────────────────────────────────────
#define BUF_SIZE      1024
#define LDR_MIN_MV    200
#define LDR_MAX_MV    3000
#define BOMBILLA_PIN  10
#define STEP_PIN      18
#define DIR_PIN       19
#define LED_PWM_PIN   4

// ─── GLOBALES ──────────────────────────────────────────────────────────────
static float    tc            = 25.0f;
static int      led_duty      = 0;
static uint64_t last_step_time = 0;

adc_oneshot_unit_handle_t adc1_handle;
adc_cali_handle_t         adc1_cali_handle;

// ─── INIT ──────────────────────────────────────────────────────────────────
void uart_init(void) {
    uart_config_t cfg = {
        .baud_rate  = 115200,
        .data_bits  = UART_DATA_8_BITS,
        .parity     = UART_PARITY_DISABLE,
        .stop_bits  = UART_STOP_BITS_1,
        .flow_ctrl  = UART_HW_FLOWCTRL_DISABLE,
        .source_clk = UART_SCLK_DEFAULT,
    };
    uart_param_config(UART_NUM_0, &cfg);
    uart_set_pin(UART_NUM_0, UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE,
                             UART_PIN_NO_CHANGE, UART_PIN_NO_CHANGE);
    uart_driver_install(UART_NUM_0, BUF_SIZE, BUF_SIZE, 0, NULL, 0);
}

void adc_init(void) {
    adc_oneshot_unit_init_cfg_t unit_cfg = { .unit_id = ADC_UNIT_1 };
    adc_oneshot_new_unit(&unit_cfg, &adc1_handle);

    adc_oneshot_chan_cfg_t chan_cfg = {
        .bitwidth = ADC_BITWIDTH_DEFAULT,
        .atten    = ADC_ATTEN_DB_12,
    };
    adc_oneshot_config_channel(adc1_handle, ADC_CHANNEL_6, &chan_cfg); // LM35
    adc_oneshot_config_channel(adc1_handle, ADC_CHANNEL_4, &chan_cfg); // LDR

    adc_cali_line_fitting_config_t cali_cfg = {
        .unit_id  = ADC_UNIT_1,
        .atten    = ADC_ATTEN_DB_12,
        .bitwidth = ADC_BITWIDTH_DEFAULT,
    };
    adc_cali_create_scheme_line_fitting(&cali_cfg, &adc1_cali_handle);
}

void bombilla_init(void) {
    gpio_config_t cfg = {
        .intr_type    = GPIO_INTR_DISABLE,
        .mode         = GPIO_MODE_OUTPUT,
        .pin_bit_mask = (1ULL << BOMBILLA_PIN),
    };
    gpio_config(&cfg);
    gpio_set_level(BOMBILLA_PIN, 0);
}

void stepper_init(void) {
    gpio_config_t cfg = {
        .intr_type    = GPIO_INTR_DISABLE,
        .mode         = GPIO_MODE_OUTPUT,
        .pin_bit_mask = (1ULL << STEP_PIN) | (1ULL << DIR_PIN),
    };
    gpio_config(&cfg);
    gpio_set_level(STEP_PIN, 0);
    gpio_set_level(DIR_PIN,  0);

    // timer con divider 80 → 1 tick = 1us
    timer_config_t timer_cfg = {
        .divider     = 80,
        .counter_dir = TIMER_COUNT_UP,
        .counter_en  = TIMER_PAUSE,
        .alarm_en    = TIMER_ALARM_DIS,
        .auto_reload = false,
    };
    timer_init(TIMER_GROUP_0, TIMER_0, &timer_cfg);
    timer_set_counter_value(TIMER_GROUP_0, TIMER_0, 0);
    timer_start(TIMER_GROUP_0, TIMER_0);
}

void leds_init(void) {
    ledc_timer_config_t timer = {
        .speed_mode      = LEDC_LOW_SPEED_MODE,
        .timer_num       = LEDC_TIMER_0,
        .duty_resolution = LEDC_TIMER_12_BIT,
        .freq_hz         = 5000,
        .clk_cfg         = LEDC_AUTO_CLK,
    };
    ledc_timer_config(&timer);

    ledc_channel_config_t channel = {
        .speed_mode = LEDC_LOW_SPEED_MODE,
        .channel    = LEDC_CHANNEL_0,
        .timer_sel  = LEDC_TIMER_0,
        .intr_type  = LEDC_INTR_DISABLE,
        .gpio_num   = LED_PWM_PIN,
        .duty       = 0,
        .hpoint     = 0,
    };
    ledc_channel_config(&channel);
}

// ─── LECTURA DE SENSORES ───────────────────────────────────────────────────
float lm35_read(void) {
    int raw, mv, suma = 0;
    for (int i = 0; i < 10; i++) {
        adc_oneshot_read(adc1_handle, ADC_CHANNEL_6, &raw);
        adc_cali_raw_to_voltage(adc1_cali_handle, raw, &mv);
        suma += mv;
    }
    // LM35: 10mV/°C → normalizado a °C
    return (suma / 10) / 10.0f;
}

float ldr_read(void) {
    int raw, mv, suma = 0;
    for (int i = 0; i < 10; i++) {
        adc_oneshot_read(adc1_handle, ADC_CHANNEL_4, &raw);
        adc_cali_raw_to_voltage(adc1_cali_handle, raw, &mv);
        suma += mv;
    }
    mv = suma / 10;

    // clamp para evitar valores fuera de rango
    if (mv < LDR_MIN_MV) mv = LDR_MIN_MV;
    if (mv > LDR_MAX_MV) mv = LDR_MAX_MV;

    // mapea el rango real a 0-100%
    return (mv - LDR_MIN_MV) * 100.0f / (LDR_MAX_MV - LDR_MIN_MV);
}

// ─── CONTROL DE ACTUADORES ─────────────────────────────────────────────────
void uart_send(float temp_control, float temp_sensor, int led_pct) {
    char buf[64];
    sprintf(buf, "Tc:%.1f T:%.1f LED:%d%%\n", temp_control, temp_sensor, led_pct);
    uart_write_bytes(UART_NUM_0, buf, strlen(buf));
}

float uart_receive_set_temp(void) {
    uint8_t rx_buf[BUF_SIZE];
    int len = uart_read_bytes(UART_NUM_0, rx_buf, BUF_SIZE - 1, 10 / portTICK_PERIOD_MS);
    if (len > 0) {
        rx_buf[len] = '\0';
        float val;
        if (sscanf((char*)rx_buf, "SET_TEMP:%f", &val) == 1) return val;
    }
    return -1;
}

void bombilla_set(bool encendida) {
    gpio_set_level(BOMBILLA_PIN, encendida);
}

void stepper_run(bool horario, int steps_per_sec) {
    uint64_t now = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &now);
    uint64_t intervalo_us = 1000000 / steps_per_sec;

    if (now - last_step_time >= intervalo_us) {
        gpio_set_level(DIR_PIN,  horario);
        gpio_set_level(STEP_PIN, 1);
        last_step_time = now;
    }
    if (now - last_step_time >= 10) {
        gpio_set_level(STEP_PIN, 0);
    }
}

void stepper_stop(void) {
    gpio_set_level(STEP_PIN, 0);
    gpio_set_level(DIR_PIN,  0);
}

void leds_set(int porcentaje) {
    int duty = (porcentaje * 4095) / 100;
    ledc_set_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_0, duty);
    ledc_update_duty(LEDC_LOW_SPEED_MODE, LEDC_CHANNEL_0);
}

// ─── APP MAIN ──────────────────────────────────────────────────────────────
void app_main(void) {
    uart_init();
    adc_init();
    bombilla_init();
    stepper_init();
    leds_init();

    while (1) {
        // recibir nueva Tc si el usuario la envió
        float nueva_tc = uart_receive_set_temp();
        if (nueva_tc != -1) tc = nueva_tc;

        float temp = lm35_read();
        float luz  = ldr_read();

        // control de temperatura y motor
        if (temp < (tc - 1.0f)) {
            bombilla_set(true);
            stepper_run(true, 100);
        } else if (temp > (tc + 1.0f) && temp < (tc + 3.0f)) {
            bombilla_set(false);
            stepper_run(false, 100);
        } else if (temp >= (tc + 3.0f) && temp <= (tc + 5.0f)) {
            bombilla_set(false);
            stepper_run(false, 300);
        } else if (temp > (tc + 5.0f)) {
            bombilla_set(false);
            stepper_run(false, 600);
        } else {
            bombilla_set(false);
            stepper_stop();
        }

        // control de iluminación
        if      (luz < 20.0f) { leds_set(100); led_duty = 100; }
        else if (luz < 30.0f) { leds_set(80);  led_duty = 80;  }
        else if (luz < 40.0f) { leds_set(60);  led_duty = 60;  }
        else if (luz < 60.0f) { leds_set(50);  led_duty = 50;  }
        else if (luz < 80.0f) { leds_set(30);  led_duty = 30;  }
        else                  { leds_set(0);   led_duty = 0;   }

        uart_send(tc, temp, led_duty);
    }
}