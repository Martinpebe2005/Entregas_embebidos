#define F1 32
#define F2 33
#define F3 25
#define F4 26
#define F5 27


#define R1 14
#define R2 16
#define R3 17
#define R4 18
#define R5 19


#define G1 21
#define G3 22
#define G5 23

// botones de figuras
#define BUTTON_1 34
#define BUTTON_2 35
#define BUTTON_3 36
#define BUTTON_4 39


#define BUTTON_START 13


#define FILA_ON 0
#define FILA_OFF 1
#define COL_ON 0
#define COL_OFF 1


// prototipos para evitar errores de compilacion

void dibujar_figura_roja(int figura);
void iniciar_mostrar_secuencia(void);
void limpiar_matrices(void);
void apagar_todo(void);
void reiniciar_variables_juego(void);
void agregar_paso(void);
void apagar_juego(void);
void iniciar_juego(void);
void refrescar_una_fila(void);
void dibujar_barrido_verde(int paso);
