static uint8_t matriz_roja[5][5];
static uint8_t matriz_verde[5][5];

static int secuencia[MAX_SEQ];
static int nivel = 1;
static int indice_usuario = 0;

static volatile bool boton_1 = false;
static volatile bool boton_2 = false;
static volatile bool boton_3 = false;
static volatile bool boton_4 = false;
static volatile bool boton_start = false;

static uint64_t now = 0;
static uint64_t last_mux = 0;
static uint64_t last_show = 0;
static uint64_t last_effect = 0;
static uint64_t last_input = 0;

// debounce por boton
static volatile uint64_t last_b1_time = 0;
static volatile uint64_t last_b2_time = 0;
static volatile uint64_t last_b3_time = 0;
static volatile uint64_t last_b4_time = 0;
static volatile uint64_t last_start_time = 0;

static int fila_actual = 0;
static int indice_secuencia = 0;
static bool figura_encendida = true;
static bool flash_usuario = false;
static int figura_usuario = -1;

static int paso_barrido = 0;
static int vueltas_barrido = 0;

static int mux_time = 1500;
static int pausa_figura = 180000;
static int flash_usuario_time = 150000;

// 0 = mostrando secuencia
// 1 = esperando usuario
// 2 = nivel superado
// 3 = perdiste
// 4 = apagado / espera
static int estado = 4;


// ISR CON DEBOUNCE

static void IRAM_ATTR button_1_isr_handler(void *arg){
    uint64_t t = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &t);

    if(t - last_b1_time >= DEBOUNCE_TIME){
        boton_1 = true;
        last_b1_time = t;
    }
}

static void IRAM_ATTR button_2_isr_handler(void *arg){
    uint64_t t = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &t);

    if(t - last_b2_time >= DEBOUNCE_TIME){
        boton_2 = true;
        last_b2_time = t;
    }
}

static void IRAM_ATTR button_3_isr_handler(void *arg){
    uint64_t t = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &t);

    if(t - last_b3_time >= DEBOUNCE_TIME){
        boton_3 = true;
        last_b3_time = t;
    }
}

static void IRAM_ATTR button_4_isr_handler(void *arg){
    uint64_t t = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &t);

    if(t - last_b4_time >= DEBOUNCE_TIME){
        boton_4 = true;
        last_b4_time = t;
    }
}

static void IRAM_ATTR button_start_isr_handler(void *arg){
    uint64_t t = 0;
    timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &t);

    if(t - last_start_time >= DEBOUNCE_TIME){
        boton_start = true;
        last_start_time = t;
    }
}


void apagar_todo(void){
    gpio_set_level(F1, FILA_OFF);
    gpio_set_level(F2, FILA_OFF);
    gpio_set_level(F3, FILA_OFF);
    gpio_set_level(F4, FILA_OFF);
    gpio_set_level(F5, FILA_OFF);

    gpio_set_level(R1, COL_OFF);
    gpio_set_level(R2, COL_OFF);
    gpio_set_level(R3, COL_OFF);
    gpio_set_level(R4, COL_OFF);
    gpio_set_level(R5, COL_OFF);

    gpio_set_level(G1, COL_OFF);
    gpio_set_level(G3, COL_OFF);
    gpio_set_level(G5, COL_OFF);
}

void limpiar_matrices(void){
    for(int i = 0; i < 5; i++){
        for(int j = 0; j < 5; j++){
            matriz_roja[i][j] = 0;
            matriz_verde[i][j] = 0;
        }
    }
}

void limpiar_banderas_botones(void){
    boton_1 = false;
    boton_2 = false;
    boton_3 = false;
    boton_4 = false;
    boton_start = false;
}

void reiniciar_variables_juego(void){
    nivel = 1;
    indice_usuario = 0;
    indice_secuencia = 0;
    figura_encendida = true;
    flash_usuario = false;
    figura_usuario = -1;
    paso_barrido = 0;
    vueltas_barrido = 0;
    fila_actual = 0;
    limpiar_banderas_botones();
}

void agregar_paso(void){
    secuencia[nivel - 1] = esp_random() % 4;
}

int tiempo_mostrar_figura(void){
    int tiempo = 700000 - (nivel - 1) * 50000;
    if(tiempo < 200000){
        tiempo = 200000;
    }
    return tiempo;
}

void apagar_juego(void){
    limpiar_matrices();
    apagar_todo();
    reiniciar_variables_juego();
    estado = 4;
}

void iniciar_juego(void){
    limpiar_matrices();
    apagar_todo();
    reiniciar_variables_juego();
    agregar_paso();
    estado = 0;
    indice_secuencia = 0;
    figura_encendida = true;
    dibujar_figura_roja(secuencia[indice_secuencia]);
    last_show = now;
}


// FIGURAS
// 0 cuadrado
// 1 x
// 2 triangulo hollow
// 3 rombo

void dibujar_cuadrado_rojo(void){
    limpiar_matrices();

    for(int c = 1; c <= 3; c++){
        matriz_roja[1][c] = 1;
        matriz_roja[3][c] = 1;
    }

    matriz_roja[2][1] = 1;
    matriz_roja[2][3] = 1;
}

void dibujar_x_rojo(void){
    limpiar_matrices();

    for(int i = 0; i < 5; i++){
        matriz_roja[i][i] = 1;
        matriz_roja[i][4 - i] = 1;
    }
}

void dibujar_triangulo_rojo(void){
    limpiar_matrices();

    matriz_roja[0][2] = 1;
    matriz_roja[1][1] = 1;
    matriz_roja[1][3] = 1;
    matriz_roja[2][1] = 1;
    matriz_roja[2][3] = 1;
    matriz_roja[3][0] = 1;
    matriz_roja[3][4] = 1;

    for(int c = 0; c < 5; c++){
        matriz_roja[4][c] = 1;
    }
}

void dibujar_rombo_rojo(void){
    limpiar_matrices();

    matriz_roja[0][2] = 1;
    matriz_roja[1][1] = 1;
    matriz_roja[1][3] = 1;
    matriz_roja[2][0] = 1;
    matriz_roja[2][4] = 1;
    matriz_roja[3][1] = 1;
    matriz_roja[3][3] = 1;
    matriz_roja[4][2] = 1;
}

void dibujar_figura_roja(int figura){
    if(figura == 0){
        dibujar_cuadrado_rojo();
    }
    else if(figura == 1){
        dibujar_x_rojo();
    }
    else if(figura == 2){
        dibujar_triangulo_rojo();
    }
    else if(figura == 3){
        dibujar_rombo_rojo();
    }
}


// BARRIDO VERDE 5x5

void dibujar_barrido_verde(int paso){
    limpiar_matrices();

    int columna = 0;

    if(paso == 0){
        columna = 0;
    }
    else if(paso == 1){
        columna = 2;
    }
    else if(paso == 2){
        columna = 4;
    }

    for(int f = 0; f < 5; f++){
        matriz_verde[f][columna] = 1;
    }
}


// MULTIPLEXADO 

void refrescar_una_fila(void){
    apagar_todo();

    if(fila_actual == 0){
        gpio_set_level(F1, FILA_ON);

        if(matriz_roja[0][0] == 1) gpio_set_level(R1, COL_ON);
        if(matriz_roja[0][1] == 1) gpio_set_level(R2, COL_ON);
        if(matriz_roja[0][2] == 1) gpio_set_level(R3, COL_ON);
        if(matriz_roja[0][3] == 1) gpio_set_level(R4, COL_ON);
        if(matriz_roja[0][4] == 1) gpio_set_level(R5, COL_ON);

        if(matriz_verde[0][0] == 1) gpio_set_level(G1, COL_ON);
        if(matriz_verde[0][2] == 1) gpio_set_level(G3, COL_ON);
        if(matriz_verde[0][4] == 1) gpio_set_level(G5, COL_ON);
    }
    else if(fila_actual == 1){
        gpio_set_level(F2, FILA_ON);

        if(matriz_roja[1][0] == 1) gpio_set_level(R1, COL_ON);
        if(matriz_roja[1][1] == 1) gpio_set_level(R2, COL_ON);
        if(matriz_roja[1][2] == 1) gpio_set_level(R3, COL_ON);
        if(matriz_roja[1][3] == 1) gpio_set_level(R4, COL_ON);
        if(matriz_roja[1][4] == 1) gpio_set_level(R5, COL_ON);

        if(matriz_verde[1][0] == 1) gpio_set_level(G1, COL_ON);
        if(matriz_verde[1][2] == 1) gpio_set_level(G3, COL_ON);
        if(matriz_verde[1][4] == 1) gpio_set_level(G5, COL_ON);
    }
    else if(fila_actual == 2){
        gpio_set_level(F3, FILA_ON);

        if(matriz_roja[2][0] == 1) gpio_set_level(R1, COL_ON);
        if(matriz_roja[2][1] == 1) gpio_set_level(R2, COL_ON);
        if(matriz_roja[2][2] == 1) gpio_set_level(R3, COL_ON);
        if(matriz_roja[2][3] == 1) gpio_set_level(R4, COL_ON);
        if(matriz_roja[2][4] == 1) gpio_set_level(R5, COL_ON);

        if(matriz_verde[2][0] == 1) gpio_set_level(G1, COL_ON);
        if(matriz_verde[2][2] == 1) gpio_set_level(G3, COL_ON);
        if(matriz_verde[2][4] == 1) gpio_set_level(G5, COL_ON);
    }
    else if(fila_actual == 3){
        gpio_set_level(F4, FILA_ON);

        if(matriz_roja[3][0] == 1) gpio_set_level(R1, COL_ON);
        if(matriz_roja[3][1] == 1) gpio_set_level(R2, COL_ON);
        if(matriz_roja[3][2] == 1) gpio_set_level(R3, COL_ON);
        if(matriz_roja[3][3] == 1) gpio_set_level(R4, COL_ON);
        if(matriz_roja[3][4] == 1) gpio_set_level(R5, COL_ON);

        if(matriz_verde[3][0] == 1) gpio_set_level(G1, COL_ON);
        if(matriz_verde[3][2] == 1) gpio_set_level(G3, COL_ON);
        if(matriz_verde[3][4] == 1) gpio_set_level(G5, COL_ON);
    }
    else if(fila_actual == 4){
        gpio_set_level(F5, FILA_ON);

        if(matriz_roja[4][0] == 1) gpio_set_level(R1, COL_ON);
        if(matriz_roja[4][1] == 1) gpio_set_level(R2, COL_ON);
        if(matriz_roja[4][2] == 1) gpio_set_level(R3, COL_ON);
        if(matriz_roja[4][3] == 1) gpio_set_level(R4, COL_ON);
        if(matriz_roja[4][4] == 1) gpio_set_level(R5, COL_ON);

        if(matriz_verde[4][0] == 1) gpio_set_level(G1, COL_ON);
        if(matriz_verde[4][2] == 1) gpio_set_level(G3, COL_ON);
        if(matriz_verde[4][4] == 1) gpio_set_level(G5, COL_ON);
    }

    fila_actual++;

    if(fila_actual > 4){
        fila_actual = 0;
    }
}


// MOSTRAR SECUENCIA

void iniciar_mostrar_secuencia(void){
    indice_secuencia = 0;
    figura_encendida = true;
    dibujar_figura_roja(secuencia[indice_secuencia]);
    last_show = now;
}

void actualizar_mostrar_secuencia(void){
    int tiempo_figura = tiempo_mostrar_figura();

    if(figura_encendida == true){
        if(now - last_show >= tiempo_figura){
            limpiar_matrices();
            figura_encendida = false;
            last_show = now;
        }
    }
    else{
        if(now - last_show >= pausa_figura){
            indice_secuencia++;

            if(indice_secuencia >= nivel){
                limpiar_matrices();
                indice_usuario = 0;
                estado = 1;
            }
            else{
                dibujar_figura_roja(secuencia[indice_secuencia]);
                figura_encendida = true;
                last_show = now;
            }
        }
    }
}


// USUARIO

void iniciar_flash_usuario(int figura){
    figura_usuario = figura;
    flash_usuario = true;
    dibujar_figura_roja(figura);
    last_input = now;
}

void actualizar_flash_usuario(void){
    if(flash_usuario == true){
        if(now - last_input >= flash_usuario_time){
            flash_usuario = false;
            limpiar_matrices();
        }
    }
}


// NIVEL SUPERADO

void iniciar_nivel_superado(void){
    paso_barrido = 0;
    vueltas_barrido = 0;
    dibujar_barrido_verde(paso_barrido);
    last_effect = now;
}

void actualizar_nivel_superado(void){
    if(now - last_effect >= 120000){
        paso_barrido++;

        if(paso_barrido > 2){
            paso_barrido = 0;
            vueltas_barrido++;
        }

        dibujar_barrido_verde(paso_barrido);
        last_effect = now;

        if(vueltas_barrido >= 3){
            nivel++;
            if(nivel > MAX_SEQ){
                nivel = MAX_SEQ;
            }
            agregar_paso();
            estado = 0;
            iniciar_mostrar_secuencia();
        }
    }
}


// GAME OVER

void prender_todo_rojo(void){
    limpiar_matrices();

    for(int f = 0; f < 5; f++){
        for(int c = 0; c < 5; c++){
            matriz_roja[f][c] = 1;
        }
    }
}

void actualizar_game_over(void){
    if(now - last_effect >= 150000){
        static bool on = false;
        on = !on;

        if(on == true){
            prender_todo_rojo();
        }
        else{
            limpiar_matrices();
        }

        last_effect = now;
        vueltas_barrido++;

        if(vueltas_barrido >= 6){
            nivel = 1;
            limpiar_matrices();
            apagar_todo();
            reiniciar_variables_juego();
            estado = 4;
        }
    }
}


// LEER BOTONES

int detectar_boton(void){
    if(boton_1 == true){
        boton_1 = false;
        return 0;
    }
    else if(boton_2 == true){
        boton_2 = false;
        return 1;
    }
    else if(boton_3 == true){
        boton_3 = false;
        return 2;
    }
    else if(boton_4 == true){
        boton_4 = false;
        return 3;
    }

    return -1;
}

void actualizar_usuario(void){
    actualizar_flash_usuario();

    if(flash_usuario == false){
        int boton = detectar_boton();

        if(boton != -1){
            iniciar_flash_usuario(boton);

            if(boton == secuencia[indice_usuario]){
                indice_usuario++;

                if(indice_usuario >= nivel){
                    estado = 2;
                    iniciar_nivel_superado();
                }
            }
            else{
                vueltas_barrido = 0;
                last_effect = now;
                estado = 3;
            }
        }
    }
}

// ==========================
// APP MAIN
// ==========================
void app_main(void){

    gpio_config_t out_cfg = {
        .pin_bit_mask =
        (1ULL << F1) | (1ULL << F2) | (1ULL << F3) | (1ULL << F4) | (1ULL << F5) |
        (1ULL << R1) | (1ULL << R2) | (1ULL << R3) | (1ULL << R4) | (1ULL << R5) |
        (1ULL << G1) | (1ULL << G3) | (1ULL << G5),
        .mode = GPIO_MODE_OUTPUT,
        .pull_up_en = GPIO_PULLUP_DISABLE,
        .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type = GPIO_INTR_DISABLE
    };
    gpio_config(&out_cfg);

    gpio_config_t in_cfg = {
        .pin_bit_mask =
        (1ULL << BUTTON_1) | (1ULL << BUTTON_2) | (1ULL << BUTTON_3) |
        (1ULL << BUTTON_4) | (1ULL << BUTTON_START),
        .mode = GPIO_MODE_INPUT,
        .pull_up_en = GPIO_PULLUP_DISABLE,
        .pull_down_en = GPIO_PULLDOWN_DISABLE,
        .intr_type = GPIO_INTR_NEGEDGE
    };
    gpio_config(&in_cfg);

    timer_config_t timer_cfg = {
        .divider = 80,
        .counter_dir = TIMER_COUNT_UP,
        .counter_en = TIMER_PAUSE,
        .alarm_en = TIMER_ALARM_DIS,
        .auto_reload = false
    };

    timer_init(TIMER_GROUP_0, TIMER_0, &timer_cfg);
    timer_set_counter_value(TIMER_GROUP_0, TIMER_0, 0);
    timer_start(TIMER_GROUP_0, TIMER_0);

    gpio_install_isr_service(0);
    gpio_isr_handler_add(BUTTON_1, button_1_isr_handler, NULL);
    gpio_isr_handler_add(BUTTON_2, button_2_isr_handler, NULL);
    gpio_isr_handler_add(BUTTON_3, button_3_isr_handler, NULL);
    gpio_isr_handler_add(BUTTON_4, button_4_isr_handler, NULL);
    gpio_isr_handler_add(BUTTON_START, button_start_isr_handler, NULL);

    apagar_todo();
    limpiar_matrices();
    reiniciar_variables_juego();
    estado = 4;

    while(1){
        timer_get_counter_value(TIMER_GROUP_0, TIMER_0, &now);

        if(now - last_mux >= mux_time){
            refrescar_una_fila();
            last_mux = now;
        }

        if(boton_start == true){
            boton_start = false;

            if(estado == 4){
                iniciar_juego();
            }
            else{
                apagar_juego();
            }
        }

        if(estado == 0){
            actualizar_mostrar_secuencia();
        }
        else if(estado == 1){
            actualizar_usuario();
        }
        else if(estado == 2){
            actualizar_nivel_superado();
        }
        else if(estado == 3){
            actualizar_game_over();
        }
        else if(estado == 4){
            limpiar_matrices();
            apagar_todo();
        }
    }
}